{
  "name": "syncfy-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js automation agent designed to manage Level 1 support. Monorepo architecture.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:frontend": "npm run dev --workspace=apps-frontend",
    "diagrams": "node scripts/generate-diagrams.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "concurrently": "^9.1.0"
  }
}
